#!/bin/sh
# Dashboardium pre-commit hook
# Проверяет: если в коммите новый файл в backend/routes/ или frontend/views/ —
# должен быть соответствующий тест в backend/test-*.js
# Если теста нет — коммит отклоняется.

CHANGED_FILES=$(git diff --cached --name-only --diff-filter=A)
HAS_ERROR=0

for file in $CHANGED_FILES; do
  # Backend routes — проверяем тест
  if echo "$file" | grep -q "^backend/routes/"; then
    basename=$(echo "$file" | sed 's/^backend\/routes\///' | sed 's/\.js$//')
    test_file="backend/test-${basename}.js"
    if [ ! -f "$test_file" ]; then
      echo "❌ Нет теста для новой фичи: $file"
      echo "   Создай $test_file перед коммитом"
      HAS_ERROR=1
    fi
  fi

  # Frontend views — проверяем тест
  if echo "$file" | grep -q "^frontend/views/"; then
    basename=$(echo "$file" | sed 's/^frontend\/views\///' | sed 's/\.js$//')
    test_file="backend/test-frontend-${basename}.js"
    if [ ! -f "$test_file" ] && [ ! -f "backend/test-${basename}.js" ]; then
      echo "⚠️  Нет теста для нового фронта: $file"
      echo "   Создай backend/test-frontend-${basename}.js или backend/test-${basename}.js"
      HAS_ERROR=1
    fi
  fi
done

if [ $HAS_ERROR -ne 0 ]; then
  echo ""
  echo "Коммит отклонён. Добавь тесты и попробуй снова."
  echo "Если тест не нужен (например, i18n-файл), добавь --no-verify"
  exit 1
fi

exit 0
