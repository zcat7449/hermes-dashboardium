# Server
PORT=3002
HOST=0.0.0.0

# Paths to Hermes Agent directories
PROFILES_DIR=$HOME/.hermes/profiles
KANBAN_BOARDS_DIR=$HOME/.hermes/kanban/boards

# Frontend static files
FRONTEND_DIR=../frontend
FRONTEND_ORIGIN=http://localhost:3000

# Hermes CLI binary name or absolute path
HERMES_BIN=hermes

# PostgreSQL connection (optional; if omitted, sessions are read-only from SQLite)
DATABASE_URL=postgres://dashboardium:dashboardium@localhost:5432/dashboardium

# Import legacy sessions from ~/.hermes/profiles/*/state.db on startup (1/true/yes to enable)
PG_IMPORT_FROM_SQLITE=true

# Rate limiting
GLOBAL_RATE_LIMIT_RPS=10
GLOBAL_RATE_LIMIT_WINDOW_MS=1000

# Hermes chat / profile switch timeouts
CHAT_TIMEOUT_MS=30000
PROFILE_SWITCH_TIMEOUT_MS=5000

# SQLite busy retry behavior
SQLITE_BUSY_RETRIES=2
SQLITE_TIMEOUT_MS=5000
