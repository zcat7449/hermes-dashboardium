# Dashboardium Configuration
PORT=3010
HOST=0.0.0.0
AUTH_USERNAME=admin
AUTH_PASSWORD=your-secure-password
# Hermes paths (auto-detected, override if needed)
# PROFILES_DIR=/home/user/.hermes/profiles
# KANBAN_BOARDS_DIR=/home/user/.hermes/kanban/boards
HERMES_BIN=hermes
# PostgreSQL (optional — for session persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/dashboardium
# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:3010
# Telegram forwarding (optional)
TELEGRAM_TARGET=telegram
